# Neon Postgres connection string (use the POOLED connection string from Neon).
# Get it at https://console.neon.tech -> your project -> Connection Details.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Shared secret protecting the /api/ingest endpoint.
# Generate one with:  openssl rand -hex 32
# Set the SAME value in Vercel env vars and in the GitHub Actions CRON_SECRET secret.
CRON_SECRET="replace-with-a-long-random-string"
