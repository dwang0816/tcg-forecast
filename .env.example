# Postgres connection string.
#
# Railway: dashboard -> your Postgres service -> Variables -> DATABASE_PUBLIC_URL.
# Use the PUBLIC one. Railway's own DATABASE_URL points at *.railway.internal,
# which only resolves from inside Railway's network — Vercel can't reach it.
DATABASE_URL="postgresql://postgres:password@xxxx.proxy.rlwy.net:12345/railway"

# Shared secret protecting the /api/ingest endpoint.
# Generate one with:  openssl rand -hex 32
# Set the SAME value in Vercel env vars and in the GitHub Actions CRON_SECRET secret.
CRON_SECRET="replace-with-a-long-random-string"

# Unlocks /admin/photos, where you eyeball each eBay listing photo and mark it
# good or bad. Generate a long random one:  openssl rand -base64 24
# Leave it unset and the page stays locked — it never falls open without it.
ADMIN_PASSCODE="replace-with-a-long-random-string"

# eBay Browse API, for finding listing photos of cards TCGplayer never shot.
# https://developer.ebay.com -> your app -> production keys
EBAY_CLIENT_ID="..."
EBAY_CLIENT_SECRET="..."
